# MemoSpark — Environment Variables
# Copy this file to .env (never commit .env) and fill in your values.
#
# Required variables are marked [REQUIRED].
# Optional variables have safe defaults shown below.

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/memospark?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&rewriteBatchedStatements=true
DB_USERNAME=root
DB_PASSWORD=your_db_password_here         # [REQUIRED]

# ── AI Service ────────────────────────────────────────────────────────────────
AI_API_KEY=your_ai_api_key_here           # [REQUIRED] OpenAI-compatible key
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_API_MODEL=deepseek-chat
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# ── Judge / Code Execution ────────────────────────────────────────────────────
# JUDGE_TYPE: judge0 (external) | container (local Docker — requires Docker installed)
JUDGE_TYPE=judge0
JUDGE0_URL=https://ce.judge0.com
JUDGE0_KEY=
JUDGE0_HOST=

# Container judge (only needed when JUDGE_TYPE=container)
JUDGE_JAVA_IMAGE=openjdk:17-slim
JUDGE_PYTHON_IMAGE=python:3.11-slim
JUDGE_TIMEOUT=10
JUDGE_MEMORY_MB=256

# ── Security tuning ───────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
