# MemoSpark production environment for docker-compose.prod.yml.
# Copy to /opt/memospark/.env on the server and fill secrets there.

APP_PORT=8080

# The app runs in Docker while MySQL listens on the host at 53306.
DB_URL=jdbc:mysql://host.docker.internal:53306/memospark?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&rewriteBatchedStatements=true
DB_USERNAME=root
DB_PASSWORD=replace-with-server-db-password

AI_API_KEY=replace-with-openai-compatible-key
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_API_MODEL=deepseek-chat
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

JUDGE_TYPE=judge0
JUDGE0_URL=https://ce.judge0.com
JUDGE0_KEY=
JUDGE0_HOST=
JUDGE_JAVA_IMAGE=openjdk:17-slim
JUDGE_PYTHON_IMAGE=python:3.11-slim
JUDGE_TIMEOUT=10
JUDGE_MEMORY_MB=256

MEMOSPARK_API_KEY=
JWT_SECRET=replace-with-random-32plus-char-secret
JWT_EXPIRY_DAYS=30
WX_APP_ID=
WX_APP_SECRET=
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
