{
  "name": "memospark-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "MemoSpark WeChat Mini-Program (Taro 3 + React)",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:weapp:prod": "node scripts/build-weapp-production.cjs",
    "validate:weapp": "node scripts/validate-weapp-deploy.cjs",
    "upload:weapp": "node scripts/upload-weapp.cjs",
    "dev:weapp": "taro build --type weapp --watch",
    "build:h5": "taro build --type h5",
    "dev:h5": "taro build --type h5 --watch"
  },
  "browserslist": ["Chrome >= 58"],
  "dependencies": {
    "@tarojs/components": "3.6.28",
    "@tarojs/helper": "3.6.28",
    "@tarojs/react": "3.6.28",
    "@tarojs/runtime": "3.6.28",
    "@tarojs/taro": "3.6.28",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@tarojs/cli": "3.6.28",
    "@tarojs/mini-runner": "3.6.28",
    "@tarojs/plugin-framework-react": "3.6.28",
    "@tarojs/webpack5-runner": "3.6.28",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "babel-preset-taro": "3.6.28",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "@tarojs/webpack5-runner": {
      "webpack": "5.78.0"
    },
    "@tarojs/webpack5-prebundle": {
      "webpack": "5.78.0"
    },
    "webpackbar": {
      "webpack": "5.78.0"
    }
  }
}
